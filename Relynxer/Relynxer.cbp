		<Unit filename="src/SendRequestThread.cpp" />
		<Unit filename="src/jsonreader.cpp" />
		<Unit filename="src/jsonval.cpp" />
		<Unit filename="src/jsonwriter.cpp" />
		<Unit filename="src/wxTranslationHelper.cpp" />
		<Unit filename="wxsmith/MoreDialog.wxs" />
		<Unit filename="wxsmith/Relynxerdialog.wxs" />
		<Unit filename="wxsmith/WaitDialog.wxs" />
		<Extensions>
			<code_completion />
			<envvars />
			<debugger />
			<wxsmith version="1">
				<gui name="wxWidgets" src="RelynxerApp.cpp" main="RelynxerDialog" init_handlers="necessary" language="CPP" />
				<resources>
					<wxDialog wxs="wxsmith/Relynxerdialog.wxs" src="RelynxerMain.cpp" hdr="RelynxerMain.h" fwddecl="0" i18n="1" name="RelynxerDialog" language="CPP" />
					<wxDialog wxs="wxsmith/WaitDialog.wxs" src="WaitDialog.cpp" hdr="WaitDialog.h" fwddecl="0" i18n="1" name="WaitDialog" language="CPP" />
					<wxDialog wxs="wxsmith/MoreDialog.wxs" src="MoreDialog.cpp" hdr="MoreDialog.h" fwddecl="0" i18n="1" name="MoreDialog" language="CPP" />
				</resources>
			</wxsmith>
		</Extensions>
	</Project>
</CodeBlocks_project_file>
